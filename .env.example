SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///./summer.db
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Agent (Summer's brain) ---
# Choose one provider and set its key.
LLM_PROVIDER=anthropic
# For Anthropic (Claude):
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6
# For OpenAI (set LLM_PROVIDER=openai and LLM_MODEL=gpt-4o-mini):
OPENAI_API_KEY=

# --- Google Calendar OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Spotify (music control; admin only) ---
# ONE-TIME setup by you, the app owner (free, ~5 min). End users NEVER see these:
#   1. Go to https://developer.spotify.com/dashboard -> Create app
#   2. Add this exact Redirect URI:  http://127.0.0.1:8000/oauth/spotify/callback
#   3. Copy the Client ID + Client Secret below.
# After that, each user just clicks "Connect Spotify" and logs in with their own
# Spotify account (Spotify Premium + an active device are required to play audio).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT=http://127.0.0.1:8000/oauth/spotify/callback

# --- ElevenLabs (HD voice) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Seedance 2.0 video (via fal.ai) ---
FAL_KEY=
SEEDANCE_FAST=1
SEEDANCE_RESOLUTION=720p
SEEDANCE_DURATION=5
SEEDANCE_ASPECT=16:9

# --- Auto event images (real photos) ---
PEXELS_API_KEY=                # real stock photos adapted to each event (free key at pexels.com/api)
# (if PEXELS_API_KEY is unset but FAL_KEY is set, Summer generates a photoreal image instead)

# --- Redirect bookings to your deployed React event site ---
EVENT_SITE_URL=                # e.g. https://your-event-site.vercel.app  -> cards show "View full event page"

# --- Video assembly (Content Studio) ---
SEEDANCE_SEGMENT_MAX=15         # max seconds per Seedance clip (fal supports 4-15)
VIDEO_MAX_SECONDS=60            # cap on total stitched length (cost/time guard)
# Voiceover uses your existing ELEVENLABS_API_KEY. Stitching/muxing needs ffmpeg on the host.

# --- Neo4j Aura (graph-RAG: prerequisite chains; admin only) ---
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
