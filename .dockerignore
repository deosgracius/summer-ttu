# Keep the backend build context small and secret-free.
.git
.github
.venv
venv
__pycache__
*.py[cod]
.pytest_cache
.mypy_cache
.ruff_cache

# never bake secrets or local data into an image
.env
.env.*
!.env.example
*.db
*.sqlite*
traces.jsonl
eval_report.json

# frontend SOURCE is needed now (the multi-stage image compiles it); its heavy
# dirs (node_modules, dist) are excluded via frontend/.dockerignore.
design
docs
*.md
.vscode
.idea
