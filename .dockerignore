# Keep the backend build context small and secret-free.
.git
.github
.venv
venv
__pycache__
*.py[cod]
.pytest_cache
.mypy_cache
.ruff_cache

# never bake secrets or local data into an image
.env
.env.*
!.env.example
*.db
*.sqlite*
traces.jsonl
eval_report.json

# frontend is built in its own image, not the backend one
frontend
design
docs
*.md
.vscode
.idea
